# Godot 4
.godot/
.import/
.godot-cache/
*.translation
*.translation.godot-cache/

# Mono / .NET (mono build of Godot generates these even for GDScript projects)
.mono/
*.csproj.user
*.sln.DotSettings.user

# Build outputs
/exports/
*.aab
*.apk
*.apk.idsig
*.x86_64
*.exe
*.pck

# Godot's Android gradle build template lives in /android/build/. Godot
# regenerates it on demand via Project → Install Android Build Template
# (200+ MB of AAR archives). We currently use the prebuilt APK template
# (gradle_build/use_gradle_build=false), so this directory is unnecessary
# in version control. If Phase 6 needs gradle (AdMob plugin), each
# developer re-installs the template locally.
/android/build/

# Signing material — NEVER commit
*.keystore
*.jks
*.p12
export_credentials.cfg
release.keystore

# Editor / OS
.vscode/
.idea/
.claude/
.DS_Store
Thumbs.db
desktop.ini

# User-local Godot data
log/
logs/

# AdMob plugin auto-installer extracts iOS xcframework binaries into
# ios/plugins/ if you happen to open the editor with the plugin enabled.
# We don't ship iOS, so skip them — keeps the repo lean.
ios/plugins/

# Generated screenshot import sidecars
screenshots/*.import
