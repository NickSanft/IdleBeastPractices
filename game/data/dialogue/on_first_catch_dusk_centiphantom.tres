script = ExtResource("1")
id = &"first_catch_dusk_centiphantom"
trigger_id = &"on_first_catch_dusk_centiphantom"
text = "Dusk centiphantom. It will tell anyone who listens that the dawn variety is shrill and the dust variety unserious. I am compelled to note it has a point."
mood = &"begrudging"
