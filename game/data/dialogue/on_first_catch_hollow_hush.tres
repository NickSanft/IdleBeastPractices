[gd_resource type="Resource" script_class="DialogueLineResource" load_steps=2 format=3]

[ext_resource type="Script" path="res://game/resources/dialogue_line_resource.gd" id="1"]

[resource]
script = ExtResource("1")
id = &"first_catch_hollow_hush"
trigger_id = &"on_first_catch_hollow_hush"
text = "Hollow hush. Phases briefly out of audible range. Pleased by silence; injured by song. The Synod tried to set its hymn to one once. It did not survive the rehearsal."
mood = &"reverent"
weight = 1.0
max_uses = 1
