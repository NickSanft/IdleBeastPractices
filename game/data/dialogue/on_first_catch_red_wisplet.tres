script = ExtResource("1")
id = &"first_catch_red_wisplet"
trigger_id = &"on_first_catch_red_wisplet"
text = "A red wisplet. Fractious, by wisp standards — meaning: about as troublesome as a damp moth. Note its disposition; it crackles when cornered."
