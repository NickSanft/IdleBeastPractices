[ext_resource type="Script" path="res://game/resources/dialogue_line_resource.gd" id="1"]

[resource]
script = ExtResource("1")
id = &"tier_complete_1"
trigger_id = &"on_tier_complete_1"
text = "Tier one is settled. The wisplets, in their entirety, are now an entry in your ledger. I shall stop short of celebrating, but I will allow myself a sigh of partial relief."
mood = &"begrudging"
weight = 1.0
max_uses = 1
