[ext_resource type="Script" path="res://game/resources/dialogue_line_resource.gd" id="1"]

[resource]
script = ExtResource("1")
id = &"tier_complete_20"
trigger_id = &"on_tier_complete_20"
text = "Tier twenty. Every nadir species, ledgered. The Synod did not, in all candour, expect you to make it this far. Neither did I. I am — note this, please — slightly unsettled by the experience of being wrong."
mood = &"reverent"
weight = 1.0
max_uses = 1
