[gd_resource type="Resource" script_class="CraftingRecipeResource" load_steps=3 format=3]

[ext_resource type="Script" path="res://game/resources/crafting_recipe_resource.gd" id="1_script"]
[ext_resource type="Resource" path="res://game/data/nets/hedgewright_net.tres" id="2_net"]

[resource]
script = ExtResource("1_script")
id = &"recipe_hedgewright_net"
