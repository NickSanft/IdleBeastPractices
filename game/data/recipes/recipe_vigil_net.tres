[gd_resource type="Resource" script_class="CraftingRecipeResource" load_steps=3 format=3]

[ext_resource type="Script" path="res://game/resources/crafting_recipe_resource.gd" id="1_script"]
[ext_resource type="Resource" path="res://game/data/nets/vigil_net.tres" id="2_net"]

[resource]
script = ExtResource("1_script")
id = &"recipe_vigil_net"
display_name = "Craft Vigil Net"
description = "Late-tier net, accessible after qualifying drops accumulate."
inputs = [{"item_id": &"refract_splinter", "amount": 350}]
output_net = ExtResource("2_net")
output_amount = 1
gold_cost = {"m": 2.64, "e": 13}
tier_required = 16
prereq_recipe_ids = Array[StringName]([&"recipe_refrain_net"])
