[gd_resource type="Resource" script_class="CraftingRecipeResource" load_steps=3 format=3]

[ext_resource type="Script" path="res://game/resources/crafting_recipe_resource.gd" id="1_script"]
[ext_resource type="Resource" path="res://game/data/nets/wraith_net.tres" id="2_net"]

[resource]
script = ExtResource("1_script")
id = &"recipe_wraith_net"
display_name = "Craft Wraith Net"
description = "Late-tier net, accessible after qualifying drops accumulate."
inputs = [{"item_id": &"wraith_cinder", "amount": 50}]
output_net = ExtResource("2_net")
output_amount = 1
gold_cost = {"m": 4.65, "e": 3}
tier_required = 4
prereq_recipe_ids = Array[StringName]([&"recipe_tier3_net"])
