; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[admob]

rewarded_unit_id=""
use_test_ad_units=true

[application]

config/name="IdleBeastPractices"
config/description="An idle monster-catching game with three currency layers, a pet auto-battler, a bestiary, monster-part crafting, and a grumpy in-world narrator."
run/main_scene="res://game/scenes/main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

Settings="*res://game/autoloads/settings.gd"
EventBus="*res://game/autoloads/event_bus.gd"
SaveManager="*res://game/autoloads/save_manager.gd"
TimeManager="*res://game/autoloads/time_manager.gd"
GameState="*res://game/autoloads/game_state.gd"
AudioManager="*res://game/autoloads/audio_manager.gd"
Narrator="*res://game/autoloads/narrator.gd"
AdsManager="*res://game/autoloads/ads_manager.gd"
GodotPlayGameServices="*uid://bin06y213u26g"
CloudSyncManager="*res://game/autoloads/cloud_sync_manager.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/stretch/mode="canvas_items"
; v0.8.5: explicitly "keep" the 720:1280 aspect with letterboxing
; rather than Godot's default non-uniform "ignore" scaling. The
; non-uniform path triggers a canvas_items input-coordinate-mapping
; bug on Android (godotengine/godot#118153) where visible buttons
; appear at the right place but tap coordinates don't transform back
; correctly. Letterboxing on the Fold7 inner display is acceptable.
window/stretch/aspect="keep"
window/handheld/orientation=1

[dotnet]

project/assembly_name="IdleBeastPractices"

[editor_plugins]

enabled=PackedStringArray("res://addons/admob/plugin.cfg", "res://addons/GodotPlayGameServices/plugin.cfg")

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
