; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[admob]

rewarded_unit_id=""
use_test_ad_units=true

[application]

config/name="IdleBeastPractices"
config/description="An idle monster-catching game with three currency layers, a pet auto-battler, a bestiary, monster-part crafting, and a grumpy in-world narrator."
run/main_scene="res://game/scenes/main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

Settings="*res://game/autoloads/settings.gd"
EventBus="*res://game/autoloads/event_bus.gd"
SaveManager="*res://game/autoloads/save_manager.gd"
TimeManager="*res://game/autoloads/time_manager.gd"
GameState="*res://game/autoloads/game_state.gd"
AudioManager="*res://game/autoloads/audio_manager.gd"
Narrator="*res://game/autoloads/narrator.gd"
AdsManager="*res://game/autoloads/ads_manager.gd"
GodotPlayGameServices="*uid://bin06y213u26g"
CloudSyncManager="*res://game/autoloads/cloud_sync_manager.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/stretch/mode="canvas_items"
; v0.8.7: switched from "keep" to "keep_width" after the v0.8.6 touch
; debug overlay screenshot conclusively showed aspect="keep" was the
; cause of the buttons-hard-to-press bug on Android. On a Galaxy Z
; Fold7 (1080x2520, 9:21 aspect), keeping the 720x1280 (9:16) viewport
; with "keep" inserted ~300 px of black letterbox at the top. Godot's
; touch input transform did NOT subtract that offset back out — taps
; at the visible top of UI were recorded at a viewport y far above
; where the user's finger landed, so the user was physically reaching
; INTO the black letterbox to make taps register.
;
; "keep_width" extends the viewport vertically (720x1680 effective on
; the Fold7) instead of letterboxing. No letterbox -> no offset math
; -> touch coordinates match the visible UI 1:1. UI elements anchored
; top-left stay where they were; bottom-anchored elements shift to
; the new viewport bottom, which is what we want on a taller device.
window/stretch/aspect="keep_width"
window/handheld/orientation=1

[dotnet]

project/assembly_name="IdleBeastPractices"

[editor_plugins]

enabled=PackedStringArray("res://addons/admob/plugin.cfg", "res://addons/GodotPlayGameServices/plugin.cfg")

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
